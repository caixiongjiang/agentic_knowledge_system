{
  "_doc": [
    "组件 LLM 配置说明（LiteLLM 时代）：",
    "1) 推荐使用 'llm_preset' 复用 config/config.toml [llm.presets.*] 里的预设；",
    "2) 也可以在 'llm' 内联完整配置：仅需 'model'（LiteLLM 'provider/model' 字符串），",
    "   可选 api_base / api_key / temperature / max_tokens / timeout / thinking_budget / extra_params；",
    "3) 'llm' 与 'llm_preset' 同时存在时，以 'llm' 字段为准（见 ComponentConfigManager.get_llm_client_for_component）。"
  ],

  "file_parser": {
    "enabled": true,
    "max_pages": 1000,
    "timeout": 300,
    "comment": "文件解析组件（Mineru）"
  },

  "text_splitter": {
    "enabled": true,
    "split_method": "structure_first",
    "chunk_size": 1000,
    "chunk_overlap": 200,
    "separators": ["\n", "。", "，", " "],
    "enable_text_clean": true,
    "comment": "文本切分组件（TextSplitter）"
  },

  "file_summary": {
    "enabled": true,
    "llm_preset": "fast",
    "max_retries": 3,
    "comment": "文件摘要组件（FileSummary）"
  },

  "kg_extractor": {
    "enabled": true,
    "llm_preset": "quality",
    "max_entities": 100,
    "max_relations": 200,
    "comment": "知识图谱提取组件（KGExtractor）"
  },

  "image_understand": {
    "enabled": true,
    "llm_preset": "multimodal",
    "max_retries": 3,
    "comment": "图片理解组件（ImageUnderstand）"
  },

  "text_analyzer": {
    "enabled": true,
    "llm_preset": "quality",
    "generate_summary": true,
    "generate_qa": true,
    "max_qa_pairs": 5,
    "comment": "文本分析组件（TextAnalyzer）"
  },

  "route_planner": {
    "enabled": true,
    "llm_preset": "reasoning",
    "llm": {
      "model": "deepseek/deepseek-reasoner",
      "temperature": 0.1,
      "max_tokens": 1024,
      "thinking_budget": 2048
    },
    "comment": "LLM₁ 路由规划器（推理型；llm 字段优先于 llm_preset）"
  },

  "result_validator": {
    "enabled": true,
    "llm_preset": "fast",
    "llm": {
      "model": "deepseek/deepseek-chat",
      "temperature": 0.3,
      "max_tokens": 2048
    },
    "comment": "LLM₂ 结果验证 Agent（OpenAI 原生 tool calling，由 LiteLLM 统一收敛）"
  },

  "mysql_writer": {
    "enabled": true,
    "batch_size": 100,
    "flush_interval": 5,
    "max_retries": 3,
    "comment": "MySQL批量写入器"
  },

  "mongo_writer": {
    "enabled": true,
    "batch_size": 50,
    "flush_interval": 5,
    "max_retries": 3,
    "comment": "MongoDB批量写入器"
  },

  "neo4j_writer": {
    "enabled": true,
    "batch_size": 200,
    "flush_interval": 10,
    "max_retries": 3,
    "comment": "Neo4j批量写入器"
  },

  "embedding_milvus_writer": {
    "enabled": true,
    "batch_size": 32,
    "flush_interval": 3,
    "max_retries": 3,
    "embedding_model": "qwen3-embedding-0.6b",
    "embedding_dim": 1024,
    "comment": "Embedding + Milvus批量写入器（合并组件）"
  }
}

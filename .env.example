# ==================== 数据库认证信息 ====================

# Milvus 认证
MILVUS_USER=root
MILVUS_PASSWORD=your_milvus_password
# Milvus token（如果使用token认证）
MILVUS_TOKEN=

# MongoDB 认证
MONGODB_USER=admin
MONGODB_PASSWORD=your_mongodb_password
# MongoDB 认证数据库
MONGODB_AUTH_SOURCE=admin
# MongoDB 连接字符串（可选，如果提供则优先使用）
MONGODB_URI=

# MySQL 认证
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password

# Neo4j 认证
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Redis 认证
REDIS_PASSWORD=your_redis_password
# Redis 用户名（Redis 6.0+支持）
REDIS_USERNAME=

# MinIO 认证
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your_minio_secret_key

# ==================== Kafka 消息队列 ====================

# Kafka 认证（如果使用SASL认证）
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# Kafka SSL证书路径（如果使用SSL）
KAFKA_SSL_CAFILE=
KAFKA_SSL_CERTFILE=
KAFKA_SSL_KEYFILE=
KAFKA_SSL_PASSWORD=

# ==================== 模型网关（LiteLLM Proxy 统一接入 LLM / Embedding / Reranker） ====================
# 业务侧所有模型调用都走 self-hosted LiteLLM Proxy，因此这里只需要两个变量；
# 各 provider 的真实 API Key（OPENAI / DEEPSEEK / GEMINI / ANTHROPIC / 智谱 / Qwen ...）
# 全部配置在 Proxy 服务端，由 Proxy 统一路由并将调用日志落到 PostgreSQL。
#
# - LITELLM_PROXY_URL : Proxy base URL，例如 http://litellm.local:4000
# - LITELLM_PROXY_KEY : 调用方 virtual key / token
#
# 不配置时，会回落到 config/config.toml 中 [proxy].api_base（推荐留空，避免
# 把生产 Endpoint 写进版本库）。
LITELLM_PROXY_URL=
LITELLM_PROXY_KEY=

# ==================== 本地直连 API Keys（未走模型网关的服务） ====================

# 稀疏向量 Embedding（BGE-M3，本地部署，未走模型网关，可选）
SPARSE_EMBEDDING_API_KEY=

# ==================== 第三方服务 ====================

# MinerU 服务（PDF 解析）
MINERU_API_KEY=

# ==================== 系统配置 ====================

# 应用环境: development, production, testing
APP_ENV=development

# 调试模式
DEBUG=true

# 应用密钥（用于加密等）
APP_SECRET_KEY=your_secret_key_change_in_production

# JWT 密钥
JWT_SECRET_KEY=your_jwt_secret_key

# 加密盐值
ENCRYPTION_SALT=your_encryption_salt
